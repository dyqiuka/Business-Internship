<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_ai_danh_gia_nang_luc" 
                                string="🤖 AI Đánh giá Năng lực" 
                                type="object" 
                                class="oe_highlight btn-info"/>
                        
                        <field name="trang_thai_lam_viec" 
                               widget="statusbar" 
                               statusbar_visible="san_sang,dang_ban,nghi_phep" 
                               options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="ho_ten_dem" class="oe_edit_only" string="Họ, đệm và Tên"/>
                            <h2>
                                <field name="ho_ten_dem" placeholder="VD: Nguyễn Văn..." style="width: 60%; margin-right: 5%;"/>
                                <field name="ten" placeholder="A" style="width: 30%;"/>
                            </h2>
                        </div>
                        <group>
                            <group string="Thông tin công việc">
                                <field name="ma_dinh_danh"/>
                                <field name="chuyen_mon"/>
                                <field name="chuc_vu"/>
                                <field name="cap_bac" widget="radio"/>
                                <field name="phong_ban_id"/>
                            </group>
                            <group string="Thông tin cá nhân">
                                <field name="gioi_tinh"/>
                                <field name="ngay_sinh"/>
                                <field name="so_dien_thoai"/>
                                <field name="email"/>
                                <field name="que_quan"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="🤖 AI Đánh giá">
                                <field name="ai_danh_gia_nang_luc" placeholder="Bấm nút 'AI Đánh giá Năng lực' ở trên để xem kết quả..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree decoration-success="trang_thai_lam_viec == 'san_sang'" decoration-danger="trang_thai_lam_viec == 'dang_ban'" decoration-muted="trang_thai_lam_viec == 'nghi_phep'">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_ten_day_du"/>
                    <field name="chuyen_mon"/>
                    <field name="cap_bac" widget="badge"/>
                    <field name="phong_ban_id"/>
                    <field name="trang_thai_lam_viec" widget="badge" decoration-success="trang_thai_lam_viec == 'san_sang'" decoration-danger="trang_thai_lam_viec == 'dang_ban'" decoration-warning="trang_thai_lam_viec == 'nghi_phep'"/>
                </tree>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field> 
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>