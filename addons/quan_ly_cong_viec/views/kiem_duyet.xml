<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_phieu_kiem_duyet_form" model="ir.ui.view">
            <field name="name">phieu_kiem_duyet.form</field>
            <field name="model">phieu_kiem_duyet</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_dong_y" 
                                string="✅ Phê duyệt &amp; Gửi Email" 
                                type="object" 
                                class="oe_highlight btn-success"
                                attrs="{'invisible': [('ket_qua_duyet', '!=', 'cho_duyet')]}"/>
                        
                        <button name="action_tu_choi" 
                                string="❌ Từ chối &amp; Bắt làm lại" 
                                type="object" 
                                class="btn-danger"
                                attrs="{'invisible': [('ket_qua_duyet', '!=', 'cho_duyet')]}"/>
                        
                        <field name="ket_qua_duyet" widget="statusbar" statusbar_visible="cho_duyet,dong_y,tu_choi"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Thông tin phiếu">
                                <field name="cong_viec_id"/>
                                <field name="nguoi_duyet_id" widget="many2one_avatar"/>
                            </group>
                            <group string="Phản hồi của Sếp hoặc trưởng phòng">
                                <field name="nhan_xet_cua_sep" 
                                       placeholder="Nếu từ chối, Sếp ghi rõ lý do vào đây để thợ biết đường sửa..."
                                       attrs="{'readonly': [('ket_qua_duyet', '!=', 'cho_duyet')], 'required': [('ket_qua_duyet', '=', 'tu_choi')]}"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="🤖 Báo cáo AI trình duyệt">
                                <div class="alert alert-info" role="alert" style="margin-bottom: 15px;">
                                    <i class="fa fa-info-circle"></i> Đây là báo cáo do AI tự động soạn thảo dựa trên ghi chú của thợ. Sếp hãy đọc kỹ trước khi duyệt nhé!
                                </div>
                                <field name="ai_bao_cao" widget="html" readonly="1" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_phieu_kiem_duyet_tree" model="ir.ui.view">
            <field name="name">phieu_kiem_duyet.tree</field>
            <field name="model">phieu_kiem_duyet</field>
            <field name="arch" type="xml">
                <tree decoration-warning="ket_qua_duyet == 'cho_duyet'" decoration-success="ket_qua_duyet == 'dong_y'" decoration-danger="ket_qua_duyet == 'tu_choi'">
                    <field name="name"/>
                    <field name="cong_viec_id"/>
                    <field name="nguoi_duyet_id" widget="many2one_avatar"/>
                    <field name="ket_qua_duyet" widget="badge" 
                           decoration-warning="ket_qua_duyet == 'cho_duyet'" 
                           decoration-success="ket_qua_duyet == 'dong_y'" 
                           decoration-danger="ket_qua_duyet == 'tu_choi'"/>
                </tree>
            </field>
        </record>

        <record id="view_phieu_kiem_duyet_search" model="ir.ui.view">
            <field name="name">phieu_kiem_duyet.search</field>
            <field name="model">phieu_kiem_duyet</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="cong_viec_id"/>
                    <field name="nguoi_duyet_id"/>
                    
                    <filter string="⏳ Đang chờ duyệt" name="cho_duyet" domain="[('ket_qua_duyet', '=', 'cho_duyet')]"/>
                    <filter string="✅ Đã phê duyệt" name="dong_y" domain="[('ket_qua_duyet', '=', 'dong_y')]"/>
                    <filter string="❌ Đã từ chối" name="tu_choi" domain="[('ket_qua_duyet', '=', 'tu_choi')]"/>
                    
                    <group expand="0" string="Gộp nhóm theo">
                        <filter string="Kết quả duyệt" name="group_ket_qua" context="{'group_by': 'ket_qua_duyet'}"/>
                        <filter string="Người kiểm duyệt" name="group_nguoi_duyet" context="{'group_by': 'nguoi_duyet_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        </data>
</odoo>