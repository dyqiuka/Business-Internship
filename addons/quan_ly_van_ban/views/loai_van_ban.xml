<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_van_ban_den_form" model="ir.ui.view">
            <field name="name">van.ban.den.form.ai</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_tom_tat_ai" type="object" string="✨ Tóm tắt bằng AI" class="oe_highlight btn-success"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ten_van_ban" placeholder="Nhập tên văn bản đến..."/>
                            </h1>
                        </div>
                        <group>
                            <group string="Thông tin chung">
                                <field name="so_van_ban_den"/>
                                <field name="so_hieu_van_ban"/>
                                <field name="loai_van_ban_id"/>
                            </group>
                            <group string="Chi tiết tiếp nhận">
                                <field name="noi_gui_den"/>
                                <field name="nhan_vien_id" options="{'no_create': True}"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Nội dung &amp; AI Tóm tắt">
                                <separator string="Kết quả AI phân tích"/>
                                <field name="ai_tom_tat" placeholder="Bấm nút 'Tóm tắt bằng AI' ở trên để tự động tạo bản tóm tắt..."/>
                                
                                <separator string="Nội dung toàn văn bản (Dán vào đây)"/>
                                <field name="noi_dung_goc" placeholder="Copy và dán toàn bộ nội dung văn bản dài vào đây..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_van_ban_den_tree" model="ir.ui.view">
            <field name="name">van.ban.den.tree</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="so_van_ban_den"/>
                    <field name="ten_van_ban"/>
                    <field name="loai_van_ban_id"/>
                    <field name="noi_gui_den"/>
                    <field name="nhan_vien_id"/>
                </tree>
            </field>
        </record>

        <record id="action_loai_van_ban" model="ir.actions.act_window">
            <field name="name">Loại văn bản</field>
            <field name="res_model">loai_van_ban</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>